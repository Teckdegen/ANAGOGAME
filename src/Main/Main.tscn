[connection signal="auth_done"         from="Onboarding"  to="." method="_on_Onboarding_auth_done"]
[connection signal="start_online_game" from="Lobby"       to="." method="_on_Lobby_start_online_game"]
[connection signal="open_leaderboard"  from="Lobby"       to="." method="_on_Lobby_open_leaderboard"]
[connection signal="open_dashboard"    from="Lobby"       to="." method="_on_Lobby_open_dashboard"]
[connection signal="game_ended"        from="Game"        to="." method="_on_Game_game_ended"]
[connection signal="back_pressed"      from="Leaderboard" to="." method="_on_Leaderboard_back_pressed"]
[connection signal="back_pressed"      from="Dashboard"   to="." method="_on_Dashboard_back_pressed"]
