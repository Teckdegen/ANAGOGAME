[ext_resource path="res://src/Main/Main.gd"                 type="Script"      id=6]

[node name="Main" type="Node"]
script = ExtResource( 6 )

[node name="Onboarding" parent="." instance=ExtResource( 1 )]

[node name="Lobby" parent="." instance=ExtResource( 2 )]
visible = false

[node name="Game" parent="." instance=ExtResource( 3 )]
